datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  OWNER
  MANAGER
  CASHIER
  KITCHEN
  WAITER
  ADMIN
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  PREPARING
  BILLING
  CLEANING
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  COOKING
  PACKING
  READY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
}

enum StaffRequestType {
  WATER
  SPOON
  TISSUE
  BILL
  CLEANING
  CALL_WAITER
}

enum RequestStatus {
  PENDING
  RESOLVED
}

model Restaurant {
  id            String          @id @default(uuid())
  name          String
  slug          String          @unique
  logo          String?
  phone         String?
  email         String?
  address       String?
  taxRate       Float           @default(5.0) // GST %
  serviceCharge Float           @default(0.0) // Service charge %
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  users         User[]
  tables        Table[]
  categories    MenuCategory[]
  menuItems     MenuItem[]
  orders        Order[]
  bills         Bill[]
  inventory     InventoryItem[]
  expenses      Expense[]
  activityLogs  ActivityLog[]
  sessions      TableSession[]
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  password     String
  name         String
  role         Role
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Table {
  id           String          @id @default(uuid())
  number       String
  capacity     Int             @default(4)
  status       TableStatus     @default(AVAILABLE)
  restaurantId String
  restaurant   Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders       Order[]
  requests     StaffRequest[]
  sessions     TableSession[]

  @@unique([restaurantId, number])
  @@index([status])
}

model TableSession {
  id           String       @id @default(uuid())
  tableId      String
  table        Table        @relation(fields: [tableId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  isActive     Boolean      @default(true)
  token        String?      // JWT Session token
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  orders       Order[]
  bills        Bill[]

  @@index([tableId])
  @@index([isActive])
}

model MenuCategory {
  id           String      @id @default(uuid())
  name         String
  description  String?
  sortOrder    Int         @default(0)
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items        MenuItem[]

  @@unique([restaurantId, name])
}

model MenuItem {
  id            String               @id @default(uuid())
  name          String
  description   String?
  price         Float
  image         String?
  prepTime      Int                  @default(15)
  isAvailable   Boolean              @default(true)
  isVeg         Boolean              @default(true)
  isBestseller  Boolean              @default(false)
  isChefSpecial Boolean              @default(false)
  categoryId    String
  category      MenuCategory         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  restaurantId  String
  restaurant    Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
  ingredients   MenuItemIngredient[]
}

model MenuItemIngredient {
  id           String        @id @default(uuid())
  menuItemId   String
  menuItem     MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   InventoryItem @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  quantityUsed Float         // e.g. 0.1 kg used per serving

  @@unique([menuItemId, ingredientId])
}

model Order {
  id             String        @id @default(uuid())
  shortId        String
  status         OrderStatus   @default(PENDING)
  tableId        String
  table          Table         @relation(fields: [tableId], references: [id])
  restaurantId   String
  restaurant     Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  totalAmount    Float         @default(0.0)
  taxAmount      Float         @default(0.0)
  discountAmount Float         @default(0.0)
  grandTotal     Float         @default(0.0)
  notes          String?
  sessionId      String?
  session        TableSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  
  items          OrderItem[]
  billId         String?
  bill           Bill?         @relation(fields: [billId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([tableId])
  @@index([restaurantId])
  @@index([sessionId])
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  price      Float
  customs    String?
  notes      String?
}

model Bill {
  id            String        @id @default(uuid())
  invoiceNo     String        @unique
  restaurantId  String
  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  subTotal      Float
  tax           Float
  discount      Float
  grandTotal    Float
  paymentMethod PaymentMethod @default(CASH)
  isPaid        Boolean       @default(false)
  paidAt        DateTime?
  sessionId     String?
  session       TableSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())

  orders        Order[]

  @@index([restaurantId])
  @@index([sessionId])
}

model StaffRequest {
  id           String           @id @default(uuid())
  tableId      String
  table        Table            @relation(fields: [tableId], references: [id], onDelete: Cascade)
  type         StaffRequestType
  status       RequestStatus    @default(PENDING)
  createdAt    DateTime         @default(now())

  @@index([status])
}

model InventoryItem {
  id           String               @id @default(uuid())
  name         String
  quantity     Float
  unit         String
  minStock     Float                @default(5.0)
  restaurantId String
  restaurant   Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  updatedAt    DateTime             @updatedAt
  menuItems    MenuItemIngredient[]
}

model Expense {
  id           String      @id @default(uuid())
  category     String
  amount       Float
  date         DateTime    @default(now())
  description  String?
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id           String      @id @default(uuid())
  action       String
  details      String?
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
}
