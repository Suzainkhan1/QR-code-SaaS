datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Restaurant {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  logo          String?
  phone         String?
  email         String?
  address       String?
  taxRate       Float    @default(5.0) // GST %
  serviceCharge Float    @default(0.0) // Service charge %
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users        User[]
  tables       Table[]
  categories   MenuCategory[]
  menuItems    MenuItem[]
  orders       Order[]
  bills        Bill[]
  inventory    InventoryItem[]
  expenses     Expense[]
  activityLogs ActivityLog[]
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  password     String
  name         String
  role         String // OWNER, MANAGER, CASHIER, KITCHEN, WAITER, ADMIN
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Table {
  id           String         @id @default(uuid())
  number       String
  capacity     Int            @default(4)
  status       String         @default("AVAILABLE") // AVAILABLE, OCCUPIED, PREPARING, BILLING, CLEANING
  restaurantId String
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders       Order[]
  requests     StaffRequest[]

  @@unique([restaurantId, number])
}

model MenuCategory {
  id           String     @id @default(uuid())
  name         String
  description  String?
  sortOrder    Int        @default(0)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items        MenuItem[]

  @@unique([restaurantId, name])
}

model MenuItem {
  id            String       @id @default(uuid())
  name          String
  description   String?
  price         Float
  image         String?
  prepTime      Int          @default(15) // In minutes
  isAvailable   Boolean      @default(true)
  isVeg         Boolean      @default(true)
  isBestseller  Boolean      @default(false)
  isChefSpecial Boolean      @default(false)
  categoryId    String
  category      MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  restaurantId  String
  restaurant    Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
}

model Order {
  id             String     @id @default(uuid())
  shortId        String // Short readable ID (e.g. #1024)
  status         String     @default("PENDING") // PENDING, ACCEPTED, PREPARING, COOKING, PACKING, READY, DELIVERED, CANCELLED
  tableId        String
  table          Table      @relation(fields: [tableId], references: [id])
  restaurantId   String
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  totalAmount    Float      @default(0.0)
  taxAmount      Float      @default(0.0)
  discountAmount Float      @default(0.0)
  grandTotal     Float      @default(0.0)
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  items OrderItem[]
  bill  Bill?
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  price      Float
  customs    String? // JSON string containing selected customizations (e.g., extra cheese, spicy level)
  notes      String?
}

model Bill {
  id            String     @id @default(uuid())
  invoiceNo     String     @unique
  orderId       String     @unique
  order         Order      @relation(fields: [orderId], references: [id])
  restaurantId  String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  subTotal      Float
  tax           Float
  discount      Float
  grandTotal    Float
  paymentMethod String     @default("CASH") // CASH, UPI, CARD
  isPaid        Boolean    @default(false)
  paidAt        DateTime?
  createdAt     DateTime   @default(now())
}

model StaffRequest {
  id        String   @id @default(uuid())
  tableId   String
  table     Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  type      String // WATER, SPOON, TISSUE, BILL, CLEANING, CALL_WAITER
  status    String   @default("PENDING") // PENDING, RESOLVED
  createdAt DateTime @default(now())
}

model InventoryItem {
  id           String     @id @default(uuid())
  name         String
  quantity     Float
  unit         String // e.g., kg, litres, units
  minStock     Float      @default(5.0) // Low stock threshold
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  updatedAt    DateTime   @updatedAt
}

model Expense {
  id           String     @id @default(uuid())
  category     String // Rent, Electricity, Salaries, Raw Materials, Maintenance, Others
  amount       Float
  date         DateTime   @default(now())
  description  String?
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id           String     @id @default(uuid())
  action       String // e.g., "New Order", "Order Completed", "Bill Generated"
  details      String? // e.g., "Table 04 placed order #1024"
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
}
